{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/amazon-appsync/json-schema/appsync-dynamodb-data-source-config-schema.json",
  "title": "DynamodbDataSourceConfig",
  "description": "DynamoDB data source configuration",
  "type": "object",
  "properties": {
    "tableName": {
      "type": "string",
      "description": "DynamoDB table name"
    },
    "awsRegion": {
      "type": "string",
      "description": "AWS Region"
    },
    "useCallerCredentials": {
      "type": "boolean",
      "description": "Whether to use caller credentials"
    },
    "deltaSyncConfig": {
      "type": "object",
      "description": "Delta sync configuration"
    },
    "versioned": {
      "type": "boolean",
      "description": "Whether versioning is enabled"
    }
  }
}