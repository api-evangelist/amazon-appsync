{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/amazon-appsync/json-schema/appsync-domain-name-config-schema.json",
  "title": "DomainNameConfig",
  "description": "Configuration for a custom domain name",
  "type": "object",
  "properties": {
    "domainName": {
      "type": "string",
      "description": "The custom domain name"
    },
    "description": {
      "type": "string",
      "description": "Domain name description"
    },
    "certificateArn": {
      "type": "string",
      "description": "ACM certificate ARN"
    },
    "appsyncDomainName": {
      "type": "string",
      "description": "AppSync CNAME for DNS setup"
    },
    "hostedZoneId": {
      "type": "string",
      "description": "Route 53 hosted zone ID"
    }
  }
}