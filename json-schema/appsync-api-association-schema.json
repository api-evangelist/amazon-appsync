{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/amazon-appsync/json-schema/appsync-api-association-schema.json",
  "title": "ApiAssociation",
  "description": "An association between a custom domain name and a GraphQL API",
  "type": "object",
  "properties": {
    "domainName": {
      "type": "string",
      "description": "The custom domain name"
    },
    "apiId": {
      "type": "string",
      "description": "The API ID"
    },
    "associationStatus": {
      "type": "string",
      "description": "The association status"
    },
    "deploymentDetail": {
      "type": "string",
      "description": "Details about the deployment"
    }
  }
}